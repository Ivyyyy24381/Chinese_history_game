{
  "id": "01_youth",
  "title": "\u5c11\u5e74\u58ee\u6e38",
  "background": "/assets/scenes/01_youth/bg.png",
  "narrative": "\u516c\u5143712\u5e74\uff0c\u675c\u752b\u51fa\u751f\u4e8e\u6cb3\u5357\u5de9\u53bf\u4e00\u4e2a\u4e66\u9999\u95e8\u7b2c\u3002\u7956\u7236\u675c\u5ba1\u8a00\u662f\u521d\u5510\u8457\u540d\u8bd7\u4eba\u3002\u5c11\u5e74\u675c\u752b\u610f\u6c14\u98ce\u53d1\uff0c20\u5c81\u5f00\u59cb\u6f2b\u6e38\u5434\u8d8a\u9f50\u9c81\uff0c\u767b\u4e34\u6cf0\u5c71\uff0c\u5199\u4e0b\u5343\u53e4\u540d\u7bc7\u3002",
  "poem": {
    "title": "\u671b\u5cb3",
    "content": "\u5cb1\u5b97\u592b\u5982\u4f55\uff1f\u9f50\u9c81\u9752\u672a\u4e86\u3002\n\u9020\u5316\u949f\u795e\u79c0\uff0c\u9634\u9633\u5272\u660f\u6653\u3002\n\u8361\u80f8\u751f\u66fe\u4e91\uff0c\u51b3\u7726\u5165\u5f52\u9e1f\u3002\n\u4f1a\u5f53\u51cc\u7edd\u9876\uff0c\u4e00\u89c8\u4f17\u5c71\u5c0f\u3002"
  },
  "dialogues": [
    {
      "speaker": "dufu",
      "speakerName": "\u675c\u752b",
      "portrait": "/assets/characters/dufu/portrait.png",
      "text": "\u7956\u7236\u5e38\u8bf4\uff0c\u8bfb\u4e07\u5377\u4e66\uff0c\u884c\u4e07\u91cc\u8def\u3002\u4eca\u65e5\u6211\u7ec8\u4e8e\u8e0f\u4e0a\u4e86\u6e38\u5386\u4e4b\u8def\uff01",
      "position": "left"
    },
    {
      "speaker": "narrator",
      "speakerName": "",
      "portrait": "",
      "text": "\u5c11\u5e74\u675c\u752b\u610f\u6c14\u98ce\u53d1\uff0c\u4ece\u6d1b\u9633\u51fa\u53d1\uff0c\u8e0f\u4e0a\u4e86\u6f2b\u6e38\u5434\u8d8a\u9f50\u9c81\u7684\u58ee\u6e38\u4e4b\u65c5\u3002",
      "position": "center"
    },
    {
      "speaker": "dufu",
      "speakerName": "\u675c\u752b",
      "portrait": "/assets/characters/dufu/portrait.png",
      "text": "\u597d\u4e00\u5ea7\u6cf0\u5c71\uff01\u5cb1\u5b97\u592b\u5982\u4f55\uff1f\u9f50\u9c81\u9752\u672a\u4e86\u2026\u2026\u6211\u5fc5\u5c06\u767b\u4e0a\u8fd9\u7edd\u9876\uff01",
      "position": "left"
    }
  ]
}
