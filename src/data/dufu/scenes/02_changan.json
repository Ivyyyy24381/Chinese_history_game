      "questions": [
        {
          "type": "choice",
          "question": "制举科目「风雅古调科」中的「风雅」，指的是以下哪部著作中的《国风》和《大雅》、《小雅》？",
          "options": [
            "《尚书》",
            "《春秋》",
            "《诗经》",
            "《礼记》"
          ],
          "answer": 2,
          "explanation": "「风雅」指的是《诗经》中的《国风》与《大雅》《小雅》，是中国最早的诗歌总集。"
        },
        {
          "type": "choice",
          "question": "现存最早的文人五言诗作者是谁？",
          "options": [
            "曹丕",
            "班固",
            "司马相如",
            "萧统"
          ],
          "answer": 1,
          "explanation": "班固的《咏史》被认为是现存最早的文人五言诗。"
        },
        {
          "type": "choice",
          "question": "扩大乐府机构，赋予其郊祀配乐职能，发生在以下哪一时期？",
          "options": [
            "西周时期",
            "东周时期",
            "西汉时期",
            "东汉时期"
          ],
          "answer": 2,
          "explanation": "汉武帝时期大规模扩大乐府机构，赋予其采集民间歌谣、配制郊祀乐曲等职能。"
        },
        {
          "type": "choice",
          "question": "以下哪个不是乐府诗常见后缀？",
          "options": [
            "歌",
            "行",
            "引",
            "序"
          ],
          "answer": 3,
          "explanation": "乐府诗常见后缀有「歌」「行」「引」「吟」「曲」等，「序」不是乐府诗的常见后缀。"
        },
        {
          "type": "choice",
          "question": "以下关于乐府诗和古体诗的关系，说法正确的是：",
          "options": [
            "乐府诗是古体诗的一类",
            "古体诗和乐府诗，同样都包含曲调",
            "乐府诗普遍抒情言志，古体诗普遍叙事为主",
            "新乐府运动所做的诗歌实际是古体诗，不算乐府诗"
          ],
          "answer": 0,
          "explanation": "乐府诗属于古体诗的范畴。古体诗不一定配曲调，而乐府诗原本是配乐演唱的。新乐府运动的诗歌继承了乐府精神，仍属乐府诗。"
        },
        {
          "type": "poem_fill",
          "question": "补全贾谊《鵩鸟赋》：\n「且夫天地为炉兮，造化为工；阴阳为炭兮，万物为___」",
          "answer": "铜",
          "distractors": [
            "金",
            "铁",
            "玉"
          ],
          "explanation": "出自贾谊《鵩鸟赋》，以天地为炉、造化为工匠、阴阳为炭火、万物为铜料，比喻万物在天地间不断变化。"
        },
        {
          "type": "poem_fill",
          "question": "补全左思《吴都赋》：\n「盖端委之所彰，高节之所兴。建至德以创洪业，世无得而___」",
          "answer": "显称",
          "distractors": [
            "比肩",
            "称道",
            "言表"
          ],
          "explanation": "出自左思《吴都赋》，赞颂吴国太伯的高尚品德与延陵季子的风范。"
        },
        {
          "type": "poem_fill",
          "question": "补全鲍照《芜城赋》：\n「直虹贯垒，长星属地。昔之虎踞龙盘，加以___」",
          "answer": "黄旗紫气",
          "distractors": [
            "龙光瑞彩",
            "紫电青霜",
            "祥云瑞霭"
          ],
          "explanation": "出自鲍照《芜城赋》，描写昔日都城的雄壮气象——虎踞龙盘之势，加上黄旗紫气的天子气象。"
        }
      ]
