      ],
      "conclusion": {
        "narrative": "\u675c\u752b\u7ec8\u4e8e\u660e\u767d\uff0c\u8fd9\u573a\u79d1\u4e3e\u4ece\u4e00\u5f00\u59cb\u5c31\u662f\u4e00\u573a\u9a97\u5c40\u3002\u5bb0\u76f8\u674e\u6797\u752b\u4e3a\u4e86\u5df2\u56fa\u6743\u4f4d\uff0c\u62c5\u5fc3\u65b0\u4eba\u5a01\u80c1\u81ea\u5df1\uff0c\u7adf\u5411\u7384\u5b97\u4e0a\u4e66\u79f0\u300c\u91ce\u65e0\u9057\u8d24\u300d\uff0c\u7f16\u9020\u65e0\u4eba\u901a\u8fc7\u7684\u7ed3\u679c\u3002\u8fd9\u4e00\u5e74\uff0c\u6240\u6709\u5e94\u8bd5\u8005\u65e0\u4e00\u4eba\u88ab\u5f55\u53d6\u3002\u675c\u752b\u7684\u4ed5\u9014\u68a6\uff0c\u5c31\u6b64\u7834\u706d\u3002",
        "poem": {
          "title": "\u5949\u8d60\u97e6\u5de6\u4e1e\u4e08\u4e8c\u5341\u4e8c\u97f5\uff08\u8282\u9009\uff09",
          "content": "\u7ee8\u7ee4\u4e0d\u997f\u6b7b\uff0c\u5112\u51a0\u591a\u8bef\u8eab\u3002\n\u4e08\u4eba\u8bd5\u9759\u542c\uff0c\u8d31\u5b50\u8bf7\u5177\u9648\u3002\n\u752b\u6614\u5c11\u5e74\u65e5\uff0c\u65e9\u5145\u89c2\u56fd\u5bbe\u3002\n\u8bfb\u4e66\u7834\u4e07\u5377\uff0c\u4e0b\u7b14\u5982\u6709\u795e\u3002"
        }
      }
    }
  ]
}
