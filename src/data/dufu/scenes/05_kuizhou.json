{
  "id": "05_kuizhou",
  "title": "\u8bd7\u6b4c\u5dc5\u5cf0",
  "background": "/assets/scenes/05_kuizhou/bg.png",
  "narrative": "765\u5e74\u4e25\u6b66\u53bb\u4e16\uff0c\u675c\u752b\u5931\u53bb\u4f9d\u9760\uff0c\u4e58\u8239\u6cbf\u957f\u6c5f\u4e1c\u4e0b\u3002\u5728\u5914\u5dde\u505c\u7559\u8fd1\u4e24\u5e74\uff0c\u5199\u4e0b\u4e86430\u591a\u9996\u8bd7\uff0c\u5305\u62ec\u300a\u767b\u9ad8\u300b\u7b49\u5dc5\u5cf0\u4e4b\u4f5c\u3002",
  "poem": {
    "title": "\u767b\u9ad8",
    "content": "\u98ce\u6025\u5929\u9ad8\u7336\u5578\u54c0\uff0c\u6e1a\u6e05\u6c99\u767d\u9e1f\u98de\u56de\u3002\n\u65e0\u8fb9\u843d\u6728\u8427\u8427\u4e0b\uff0c\u4e0d\u5c3d\u957f\u6c5f\u6eda\u6eda\u6765\u3002\n\u4e07\u91cc\u60b2\u79cb\u5e38\u4f5c\u5ba2\uff0c\u767e\u5e74\u591a\u75c5\u72ec\u767b\u53f0\u3002\n\u8270\u96be\u82e6\u6068\u7e41\u971c\u9b13\uff0c\u6f66\u5012\u65b0\u505c\u6d4a\u9152\u676f\u3002"
  },
  "dialogues": [
    {
      "speaker": "narrator",
      "speakerName": "",
      "portrait": "",
      "text": "\u4e25\u6b66\u53bb\u4e16\u540e\uff0c\u675c\u752b\u5931\u53bb\u4e86\u6700\u540e\u7684\u4f9d\u9760\uff0c\u53ea\u5f97\u4e58\u8239\u4e1c\u4e0b\u3002",
      "position": "center"
    },
    {
      "speaker": "dufu",
      "speakerName": "\u675c\u752b",
      "portrait": "/assets/characters/dufu/portrait.png",
      "text": "\u4e07\u91cc\u60b2\u79cb\u5e38\u4f5c\u5ba2\uff0c\u767e\u5e74\u591a\u75c5\u72ec\u767b\u53f0\u2026\u2026\u8fd9\u4e00\u751f\uff0c\u7ec8\u662f\u98d8\u96f6\u3002",
      "position": "left"
    },
    {
      "speaker": "boatman",
      "speakerName": "\u8239\u592b",
      "portrait": "/assets/characters/npcs/boatman.png",
      "text": "\u5148\u751f\uff0c\u5914\u5dde\u5230\u4e86\u3002\u8fd9\u91cc\u5ce1\u6c5f\u58ee\u9614\uff0c\u60a8\u53ef\u4ee5\u5728\u6b64\u4f11\u517b\u4e00\u9635\u3002",
      "position": "right"
    }
  ]
