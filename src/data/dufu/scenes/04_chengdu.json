{
  "id": "04_chengdu",
  "title": "\u6d63\u82b1\u6eaa\u7554",
  "background": "/assets/scenes/04_chengdu/bg.png",
  "narrative": "\u516c\u5143759\u5e74\uff0c\u675c\u752b\u8f97\u8f6c\u6765\u5230\u6210\u90fd\uff0c\u5728\u6d63\u82b1\u6eaa\u7554\u5efa\u8d77\u4e86\u4e00\u5ea7\u8349\u5802\u3002\u597d\u53cb\u4e25\u6b66\u591a\u6b21\u63a5\u6d4e\u4ed6\u3002\u8fd9\u662f\u675c\u752b\u4e00\u751f\u4e2d\u6700\u5b89\u5b9a\u7684\u65f6\u671f\u3002",
  "poem": {
    "title": "\u8305\u5c4b\u4e3a\u79cb\u98ce\u6240\u7834\u6b4c\uff08\u8282\u9009\uff09",
    "content": "\u516b\u6708\u79cb\u9ad8\u98ce\u6012\u53f7\uff0c\u5377\u6211\u5c4b\u4e0a\u4e09\u91cd\u8305\u3002\n\u2026\u2026\n\u5b89\u5f97\u5e7f\u53a6\u5343\u4e07\u95f4\uff0c\u5927\u5e87\u5929\u4e0b\u5bd2\u58eb\u4ff1\u6b22\u989c\uff01\n\u543e\u5e90\u72ec\u7834\u53d7\u51bb\u6b7b\u4ea6\u8db3\uff01"
  },
  "dialogues": [
    {
      "speaker": "dufu",
      "speakerName": "\u675c\u752b",
      "portrait": "/assets/characters/dufu/portrait.png",
      "text": "\u8fd9\u6d63\u82b1\u6eaa\u7554\uff0c\u5c71\u6e05\u6c34\u79c0\uff0c\u7ec8\u4e8e\u53ef\u4ee5\u5b89\u5b9a\u4e0b\u6765\u4e86\u3002",
      "position": "left"
    },
    {
      "speaker": "yanwu",
      "speakerName": "\u4e25\u6b66",
      "portrait": "/assets/characters/npcs/yanwu.png",
      "text": "\u5b50\u7f8e\u5144\uff0c\u6211\u5df2\u8ba9\u4eba\u9001\u6765\u6750\u6599\uff0c\u8fd9\u8349\u5802\u867d\u7b80\u964b\uff0c\u4f46\u8db3\u4ee5\u907f\u98ce\u96e8\u3002",
      "position": "right"
    },
    {
      "speaker": "dufu",
      "speakerName": "\u675c\u752b",
      "portrait": "/assets/characters/dufu/portrait.png",
      "text": "\u591a\u8c22\u4e25\u5144\u63a5\u6d4e\u3002\u53ea\u662f\u2026\u2026\u6211\u867d\u6709\u4e86\u5bb9\u8eab\u4e4b\u6240\uff0c\u5929\u4e0b\u5bd2\u58eb\u53c8\u5f53\u5982\u4f55\uff1f",
      "position": "left"
    }
  ]
}
