{
  "id": "755_anshi",
  "title": "安史之乱爆发",
  "year": "755",
  "type": "interactive",
  "phases": [
    {
      "id": "ru_shi_home",
      "type": "explore",
      "background": "/assets/events/751_lifu/backgrounds/dufu_home.png",
      "title": "入仕 · 杜甫家中",
      "narrative": "天宝十四载（755）十月。长安。困守长安十年，杜甫终于等到了任命。",
      "instruction": "查看桌案上的委任状。",
      "npcs": [
        {
          "id": "appointment_letter",
          "name": "委任状",
          "position": {
            "x": 47,
            "y": 66
          },
          "scale": 0.9,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "text": "桌案上摊着一封朱印诏书——「除杜甫为河西尉。」"
            },
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "等待四年，终于得到了朝廷的委任。"
            },
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "河西尉？一个负责缉捕盗匪的九品小员？"
            }
          ]
        }
      ],
      "requiredTalks": 1
    },
    {
      "id": "ru_shi_choice",
      "type": "forced_choice",
      "background": "/assets/events/751_lifu/backgrounds/dufu_home.png",
      "title": "入仕 · 该如何回应",
      "narrative": "杜甫提笔欲奏。但该说什么呢？",
      "question": "杜甫该如何拒绝这份任命？",
      "options": [
        {
          "id": "self",
          "text": "「不作河西尉，凄凉为折腰。」",
          "correct": true,
          "response": {
            "speaker": "dufu",
            "speakerName": "杜甫",
            "text": "这是我自己的话。河西尉，我不去。"
          }
        },
        {
          "id": "libai",
          "text": "「安能摧眉折腰事权贵，使我不得开心颜？」",
          "correct": false,
          "response": {
            "speaker": "dufu",
            "speakerName": "杜甫",
            "text": "（顿）……这是太白的句子，不是我的。"
          }
        },
        {
          "id": "menghaoran",
          "text": "「不才明主弃，多病故人疏。」",
          "correct": false,
          "response": {
            "speaker": "dufu",
            "speakerName": "杜甫",
            "text": "（顿）……这是孟襄阳的句子。我有我自己的话。"
          }
        }
      ],
      "conclusion": {
        "narrative": "杜甫上书婉拒。朝堂上又起了波澜。"
      }
    },
    {
      "id": "ru_shi_court",
      "type": "transition",
      "background": "/assets/events/747_exam/backgrounds/palace_outside.png",
      "title": "入仕 · 朝堂",
      "transitionText": "数日后，尚书省。一封婉拒的奏疏摆在案头。",
      "announcement": {
        "text": "改除杜甫为右卫率府兵曹参军。",
        "style": "imperial_decree"
      },
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/portrait.png",
        "text": "看管兵器……也好。总比河西尉强。"
      },
      "narrative": ""
    },
    {
      "id": "fanyang_rumor",
      "type": "explore",
      "background": "/assets/events/755_anshi/backgrounds/changan_winter.png",
      "title": "长安·烽烟传来",
      "narrative": "天宝十四载（755）十一月，长安。一封塘报从北方驿道飞驰而来。",
      "instruction": "点击周围的人物，听听他们怎么说『安禄山反了』。",
      "npcs": [
        {
          "id": "messenger",
          "name": "驿卒",
          "portrait": "/assets/characters/npcs/messenger.png",
          "position": {
            "x": 66,
            "y": 74
          },
          "scale": 1.1,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "messenger",
              "speakerName": "驿卒（喘）",
              "text": "范阳——范阳起兵了！安禄山反了！"
            },
            {
              "speaker": "messenger",
              "speakerName": "驿卒",
              "text": "沿途州县望风披靡，没人挡得住！"
            }
          ]
        },
        {
          "id": "commoner_a",
          "name": "百姓甲",
          "portrait": "/assets/characters/npcs/merchant_a.png",
          "position": {
            "x": 22,
            "y": 80
          },
          "scale": 1.1,
          "dialogues": [
            {
              "speaker": "commoner_a",
              "speakerName": "百姓甲",
              "text": "胡说！圣人正在华清池，安将军是义子，怎会造反？"
            },
            {
              "speaker": "commoner_a",
              "speakerName": "百姓甲",
              "text": "你莫不是吃了酒乱报？"
            }
          ]
        },
        {
          "id": "commoner_b",
          "name": "百姓乙",
          "portrait": "/assets/characters/npcs/merchant_b.png",
          "position": {
            "x": 33,
            "y": 79
          },
          "scale": 1.2,
          "dialogues": [
            {
              "speaker": "commoner_b",
              "speakerName": "百姓乙",
              "text": "驿卒怎敢妄言……"
            },
            {
              "speaker": "commoner_b",
              "speakerName": "百姓乙",
              "text": "可若是真的——天下要乱了。"
            }
          ]
        },
        {
          "id": "official",
          "name": "路过官员",
          "portrait": "/assets/characters/npcs/official.png",
          "position": {
            "x": 57,
            "y": 76
          },
          "scale": 1.2,
          "flip": true,
          "dialogues": [
            {
              "speaker": "official",
              "speakerName": "官员（疾走）",
              "text": "速去告知宰相！"
            },
            {
              "speaker": "official",
              "speakerName": "官员",
              "text": "不可声张！不可声张！"
            }
          ]
        },
        {
          "id": "poster",
          "name": "街头告示",
          "portrait": "",
          "position": {
            "x": 79,
            "y": 63
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "speakerName": "告示",
              "text": "「谋反逆者，凡有所言皆斩。」"
            },
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "这盛世……"
            }
          ]
        }
      ],
      "requiredTalks": 3,
      "nextPhase": "changan_falls"
    },
    {
      "id": "changan_falls",
      "type": "transition",
      "background": "/assets/events/755_anshi/backgrounds/changan_burning.png",
      "title": "长安陷落",
      "transitionText": "天宝十五载六月。\n潼关失守。\n玄宗连夜出奔蜀地。\n长安无主。",
      "announcement": {
        "text": "「车驾西幸蜀郡，朕将与万民共艰。」——御诏",
        "style": "imperial_decree"
      },
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/portrait.png",
        "text": "我把家人安顿在鄜州，自己却走不出长安。"
      },
      "nextPhase": "besieged",
      "narrative": ""
    },
    {
      "id": "besieged",
      "type": "explore",
      "background": "/assets/events/755_anshi/backgrounds/changan_ruin.png",
      "title": "沦陷的长安",
      "narrative": "叛军入城。残垣，乱兵。城中再无禁卫。",
      "instruction": "在沦陷的长安城里走动，记住你看到的一切。",
      "npcs": [
        {
          "id": "refugee_woman",
          "name": "难民妇人",
          "portrait": "/assets/characters/npcs/refugee_woman.png",
          "position": {
            "x": 33,
            "y": 67
          },
          "scale": 1.4,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "refugee_woman",
              "speakerName": "难民妇人",
              "text": "我们的儿子——被叛军抓走了！"
            },
            {
              "speaker": "refugee_woman",
              "speakerName": "难民妇人",
              "text": "他才十六岁，他才十六岁啊！"
            }
          ]
        },
        {
          "id": "refugee_old",
          "name": "难民老汉",
          "portrait": "/assets/characters/npcs/refugee_old.png",
          "position": {
            "x": 48,
            "y": 70
          },
          "scale": 1.3,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "refugee_old",
              "speakerName": "难民老汉",
              "text": "天子也跑了，我们能往哪里去？"
            },
            {
              "speaker": "refugee_old",
              "speakerName": "难民老汉",
              "text": "……活一天算一天罢。"
            }
          ]
        },
        {
          "id": "rebel_officer",
          "name": "叛军军官",
          "portrait": "/assets/characters/npcs/rebel_officer.png",
          "position": {
            "x": 76,
            "y": 68
          },
          "scale": 1.5,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "rebel_officer",
              "speakerName": "叛军军官",
              "text": "凡留城者，皆为叛贼之民！"
            },
            {
              "speaker": "rebel_officer",
              "speakerName": "叛军军官",
              "text": "敢出城者，斩。"
            }
          ]
        },
        {
          "id": "wall_inscription",
          "name": "城墙刻字",
          "portrait": "",
          "position": {
            "x": 58,
            "y": 68
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "speakerName": "旁白",
              "text": "不知何人刻在墙根：「国破山河在，城春草木深。」"
            },
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "……这是我心里的话。"
            }
          ]
        }
      ],
      "requiredTalks": 3,
      "nextPhase": "chunwang"
    },
    {
      "id": "chunwang",
      "type": "click_points",
      "background": "/assets/events/755_anshi/backgrounds/chunwang_scene.png",
      "title": "《春望》·画面独白",
      "narrative": "杜甫站在长安城头，远望残破宫城。",
      "instruction": "画面里藏着 7 个杜甫的心事——点击它们，听他写下心中的句子",
      "unlockThreshold": 3,
      "points": [
        {
          "id": "beacon",
          "label": "烽火",
          "position": {
            "x": 41,
            "y": 28
          },
          "size": 104,
          "text": "烽火悬在云边久，胡马来后未得熄。"
        },
        {
          "id": "peach",
          "label": "桃花树枝",
          "position": {
            "x": 86,
            "y": 11
          },
          "size": 162,
          "text": "故国春花不知意，是春依旧烂漫开。"
        },
        {
          "id": "city",
          "label": "长安城",
          "position": {
            "x": 59,
            "y": 59
          },
          "size": 64,
          "text": "长安城里屋舍在，圣人车辇今何之？"
        },
        {
          "id": "wall",
          "label": "围墙",
          "position": {
            "x": 97,
            "y": 44
          },
          "size": 200,
          "text": "城郭陷落日萧条，支离围墙空落寞。"
        },
        {
          "id": "book",
          "label": "书本",
          "position": {
            "x": 72,
            "y": 55
          },
          "size": 64,
          "text": "欲问鄜州闺中事，独在西都不得知。"
        },
        {
          "id": "bird",
          "label": "鸟",
          "position": {
            "x": 38,
            "y": 68
          },
          "size": 100,
          "text": "嘶鸣偏和破阵乐，啼叫犹带泣血声。"
        },
        {
          "id": "flower",
          "label": "下方花",
          "position": {
            "x": 12,
            "y": 86
          },
          "size": 114,
          "text": "空见落花红池沼，玉箸一夜为谁流。"
        }
      ],
      "progressivePoem": [
        "国破山河在，城春草木深。",
        "感时花溅泪，恨别鸟惊心。",
        "烽火连三月，家书抵万金。",
        "白头搔更短，浑欲不胜簪。"
      ],
      "image": "/assets/events/755_anshi/backgrounds/chunwang_scene.png"
    },
