{
  "id": "757_zuoshiyi",
  "title": "任左拾遗",
  "year": "757",
  "type": "interactive",
  "phases": [
    {
      "id": "escape_road",
      "type": "map_travel",
      "background": "/assets/maps/route_757_fengxiang.png",
      "title": "奔赴凤翔",
      "travelNarrative": "至德二载（757）四月。杜甫衣衫褴褛地从长安西金光门出，穿越叛军封锁线。",
      "instruction": "点击每一站，看杜甫如何走完这段险路。",
      "requireAll": true,
      "waypoints": [
        {
          "id": "jinguangmen",
          "name": "金光门",
          "x": 80,
          "y": 53,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "天黑前必须出金光门。"
            }
          ]
        },
        {
          "id": "meet_refugee",
          "name": "途中",
          "x": 70,
          "y": 45,
          "isKey": true,
          "dialogues": [
            {
              "speaker": "refugee",
              "speakerName": "难民",
              "text": "先生，前方叛军重重，您还要往凤翔去？太危险了！"
            },
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "肃宗在凤翔即位，我虽一介布衣，也要报效国家！"
            }
          ]
        },
        {
          "id": "wei_river",
          "name": "渭水",
          "x": 52,
          "y": 38,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "渡水。鞋已破。"
            }
          ]
        },
        {
          "id": "fengxiang_gate",
          "name": "凤翔",
          "x": 17,
          "y": 29,
          "isKey": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "speakerName": "旁白",
              "text": "至德二载四月，杜甫衣衫褴褛地走进凤翔。"
            }
          ]
        }
      ],
      "nextPhase": "audience",
      "narrative": ""
    },
    {
      "id": "audience",
      "type": "transition",
      "background": "/assets/events/757_zuoshiyi/backgrounds/fengxiang_hall.png",
      "title": "拜见肃宗",
      "transitionText": "肃宗见杜甫『麻鞋见天子，衣袖露两肘』，感其忠，授左拾遗。",
      "announcement": {
        "text": "「除杜甫为左拾遗。」——肃宗诏",
        "style": "imperial_decree",
        "title": "诏"
      },
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/official/standing.png",
        "text": "臣……必尽言责。"
      },
      "nextPhase": "fangguan_case",
      "narrative": ""
    },
    {
      "id": "fangguan_case",
      "type": "explore",
      "background": "/assets/events/757_zuoshiyi/backgrounds/fengxiang_office.png",
      "title": "房琯案",
      "narrative": "上任不到一月，宰相房琯因陈陶斜兵败被罢相。一封弹劾的奏疏已上。",
      "instruction": "了解房琯案的来龙去脉，再决定要不要救他。",
      "npcs": [
        {
          "id": "colleague_advice",
          "name": "同僚",
          "portrait": "/assets/characters/npcs/scholar_a.png",
          "position": {
            "x": 11,
            "y": 70
          },
          "scale": 3,
          "flip": true,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "colleague_advice",
              "speakerName": "同僚",
              "text": "房相败得太惨了。两千车牛，全军覆没。"
            },
            {
              "speaker": "colleague_advice",
              "speakerName": "同僚",
              "text": "但败兵之将不可重罚——这是惯例。"
            }
          ]
        },
        {
          "id": "accuser",
          "name": "御史",
          "portrait": "/assets/characters/npcs/accuser.png",
          "position": {
            "x": 86,
            "y": 51
          },
          "scale": 3,
          "flip": true,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "accuser",
              "speakerName": "御史",
              "text": "房琯轻敌冒进，丧师辱国，必当重处。"
            },
            {
              "speaker": "accuser",
              "speakerName": "御史",
              "text": "圣人正在气头上。谁敢求情，谁就是同党。"
            }
          ]
        },
        {
          "id": "memorial",
          "name": "弹劾奏疏",
          "portrait": "",
          "position": {
            "x": 43,
            "y": 62
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "speakerName": "奏疏",
              "text": "「房琯庸缪，丧师万千。请正典刑，以谢天下。」"
            }
          ]
        },
        {
          "id": "friend",
          "name": "朋友",
          "portrait": "/assets/characters/npcs/gaoshi.png",
          "position": {
            "x": 76,
            "y": 68
          },
          "scale": 3,
          "dialogues": [
            {
              "speaker": "friend",
              "speakerName": "朋友",
              "text": "子美，你才上任。这事别管。"
            }
          ]
        }
      ],
      "requiredTalks": 3,
      "nextPhase": "shusu_choice"
    },
    {
      "id": "shusu_choice",
      "type": "forced_choice",
      "background": "/assets/events/757_zuoshiyi/backgrounds/fengxiang_office.png",
      "title": "上疏",
      "narrative": "案头铺开一张白纸。",
      "question": "你要不要上疏救房琯？",
      "options": [
        {
          "id": "save",
          "text": "上疏救房琯",
          "correct": true,
          "response": {
            "speaker": "dufu",
            "speakerName": "杜甫",
            "text": "拾遗者，正为此时。"
          }
        },
        {
          "id": "silent",
          "text": "沉默以保自身",
          "correct": false,
          "response": {
            "speaker": "dufu",
            "speakerName": "杜甫",
            "text": "……我不能。\n（但这官，便不是拾遗了。）"
          }
        },
        {
          "id": "join_accuser",
          "text": "顺势附和弹劾",
          "correct": false,
          "response": {
            "speaker": "dufu",
            "speakerName": "杜甫",
            "text": "（笔顿）不可。"
          }
        }
      ],
      "conclusion": {
        "narrative": "奏疏上达。"
      }
    },
    {
      "id": "imperial_wrath",
      "type": "transition",
      "background": "/assets/events/757_zuoshiyi/backgrounds/fengxiang_hall.png",
      "title": "圣怒",
      "transitionText": "奏疏上达。\n肃宗大怒。",
      "announcement": {
        "text": "「杜甫党比，付三司推问。」——肃宗诏\n（张镐力救：『甫若抵罪，绝言者路。』乃免。）",
        "style": "imperial_decree",
        "title": "诏"
      },
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/official/standing.png",
        "text": "臣，不敢自辩。但臣所言，皆为社稷。"
      },
      "nextPhase": "home_visit",
      "narrative": ""
    },
