{
  "id": "770_xiangjiang",
  "title": "病死舟中",
  "year": "770",
  "type": "interactive",
  "phases": [
    {
      "id": "out_of_kuizhou",
      "type": "transition",
      "background": "/assets/events/770_xiangjiang/backgrounds/jianjling_river.png",
      "title": "出夔州后",
      "transitionText": "大历三年（768）春。\n杜甫携家出三峡。",
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/portrait.png",
        "text": "往哪里去呢？故乡是不能回了。"
      },
      "nextPhase": "yueyang_lou"
    },
    {
      "id": "yueyang_lou",
      "type": "explore",
      "background": "/assets/events/770_xiangjiang/backgrounds/yueyang_lou.png",
      "title": "岳阳楼",
      "narrative": "大历三年冬。杜甫终于登上久闻其名的岳阳楼。",
      "instruction": "登楼远望——四个方向，四种心情。",
      "npcs": [
        {
          "id": "dongting",
          "name": "洞庭水",
          "portrait": "",
          "position": { "x": 30, "y": 55 },
          "isClue": true,
          "dialogues": [
            { "speaker": "dufu", "speakerName": "杜甫", "text": "昔闻洞庭水，今上岳阳楼。" }
          ]
        },
        {
          "id": "wupu",
          "name": "吴楚分界",
          "portrait": "",
          "position": { "x": 55, "y": 50 },
          "isClue": true,
          "dialogues": [
            { "speaker": "dufu", "speakerName": "杜甫", "text": "吴楚东南坼，乾坤日夜浮。" }
          ]
        },
        {
          "id": "letter",
          "name": "未回的家书",
          "portrait": "",
          "position": { "x": 75, "y": 65 },
          "isClue": true,
          "dialogues": [
            { "speaker": "dufu", "speakerName": "杜甫", "text": "亲朋无一字，老病有孤舟。" }
          ]
        },
        {
          "id": "north",
          "name": "北望",
          "portrait": "",
          "position": { "x": 50, "y": 30 },
          "isClue": true,
          "dialogues": [
            { "speaker": "dufu", "speakerName": "杜甫", "text": "戎马关山北……" },
            { "speaker": "dufu", "speakerName": "杜甫", "text": "凭轩涕泗流。" }
          ]
        }
      ],
      "requiredTalks": 4,
      "nextPhase": "drift_route"
    },
    {
      "id": "drift_route",
      "type": "map_travel",
      "background": "/assets/maps/tang_dynasty.png",
      "title": "漂泊路线",
      "travelNarrative": "大历四年（769）至大历五年（770）。杜甫携家漂泊于潭州、衡州、耒阳之间。",
      "instruction": "依次点击每一个停点。",
      "requireAll": true,
      "waypoints": [
        {
          "id": "jiangling",
          "name": "江陵",
          "x": 58, "y": 60,
          "dialogues": [
            { "speaker": "dufu", "speakerName": "杜甫", "text": "投亲不得。停舟江陵。" }
          ]
        },
        {
          "id": "gongan",
          "name": "公安",
          "x": 59, "y": 62,
          "dialogues": [
            { "speaker": "dufu", "speakerName": "杜甫", "text": "呜呼！何路寄此身？" }
          ]
        },
        {
          "id": "tanzhou",
          "name": "潭州",
          "x": 60, "y": 66,
          "isKey": true,
          "dialogues": [
            { "speaker": "dufu", "speakerName": "杜甫", "text": "岁暮百草零，疾风高冈裂。" }
          ]
        },
        {
          "id": "hengzhou",
          "name": "衡州",
          "x": 61, "y": 68,
          "dialogues": [
            { "speaker": "dufu", "speakerName": "杜甫", "text": "老病有孤舟。" }
          ]
        },
        {
          "id": "leiyang",
          "name": "耒阳",
          "x": 62, "y": 70,
          "isKey": true,
          "dialogues": [
            { "speaker": "narrator", "speakerName": "旁白", "text": "（大水阻舟，停在方田驿。县令送来酒肉。）" }
          ]
        }
      ],
      "nextPhase": "dream"
    },
    {
      "id": "dream",
      "type": "explore",
      "background": "/assets/events/770_xiangjiang/backgrounds/old_river_dream.png",
      "title": "回忆",
      "narrative": "夜泊。江上起雾。杜甫在船舱里睡去，梦见了从前。",
      "instruction": "点开浮在江面上的影子。",
      "npcs": [
        {
          "id": "libai_dream",
          "name": "李白·影",
          "portrait": "/assets/characters/npcs/libai.png",
          "position": { "x": 50, "y": 50 },
          "scale": 1.5,
          "isClue": true,
          "dialogues": [
            { "speaker": "libai", "speakerName": "李白", "text": "子美，我读了你的诗。十年了。" },
            { "speaker": "libai", "speakerName": "李白", "text": "（笑声穿过雾——也可能根本没有人。）" }
          ]
        },
        {
          "id": "yanwu_dream",
          "name": "严武·影",
          "portrait": "/assets/characters/npcs/yanwu.png",
          "position": { "x": 25, "y": 60 },
          "scale": 1.3,
          "dialogues": [
            { "speaker": "yanwu", "speakerName": "严武", "text": "子美兄，草堂还在。" }
          ]
        },
        {
          "id": "wife_dream",
          "name": "妻·影",
          "portrait": "/assets/characters/npcs/wife.png",
          "position": { "x": 75, "y": 65 },
          "scale": 1.2,
          "dialogues": [
            { "speaker": "wife", "speakerName": "妻", "text": "回家吧。" }
          ]
        }
      ],
      "requiredTalks": 1,
      "nextPhase": "ending"
    },
    {
      "id": "ending",
      "type": "transition",
      "background": "/assets/events/770_xiangjiang/backgrounds/leiyang_boat.png",
      "title": "耒阳·终焉",
      "transitionText": "大历五年（770）冬。\n由潭州前往岳阳。\n途中遇大水，舟阻方田驿数日。\n县令送来酒肉。\n五十九岁的杜甫，已无法起身。",
      "announcement": {
        "text": "大历五年冬，杜甫卒于由潭州赴岳阳之舟中，年五十九。",
        "style": "imperial_decree"
      },
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/portrait.png",
        "text": "战血流依旧，军声动至今……"
      },
      "nextPhase": "epilogue"
    },
    {
      "id": "epilogue",
      "type": "transition",
      "background": "/assets/events/770_xiangjiang/backgrounds/leiyang_boat.png",
      "title": "尾声·后世",
      "transitionText": "四十三年后，元和八年（813）。\n其孙杜嗣业奉杜甫灵柩归葬偃师，路过荆州时，请元稹作墓志。",
      "announcement": {
        "text": "「至于子美，盖所谓上薄风骚，下该沈宋，言夺苏李，气吞曹刘……诗人以来，未有如子美者。」——元稹",
        "style": "imperial_decree"
      },
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/portrait.png",
        "text": "（他生前未得名。死后一千两百年，他是诗圣。）"
      }
    }
  ]
}
