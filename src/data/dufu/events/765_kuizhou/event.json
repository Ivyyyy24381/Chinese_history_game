      "title": "三峡水路",
      "travelNarrative": "永泰元年（765）秋。严武去世后，杜甫携家乘舟东下，沿长江过三峡。",
      "instruction": "点击每一站，听一段独白。",
      "requireAll": true,
      "waypoints": [
        {
          "id": "jiazhou",
          "name": "嘉州",
          "x": 14,
          "y": 76,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "青衣江口看潮生，思君何处更登台？"
            }
          ]
        },
        {
          "id": "zhongzhou",
          "name": "忠州",
          "x": 61,
          "y": 62,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "我病多时不饮酒。寄人篱下又一城。"
            }
          ]
        },
        {
          "id": "yunan",
          "name": "云安",
          "x": 67,
          "y": 43,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "久客江南，岂能无恙。"
            }
          ]
        },
        {
          "id": "kuizhou",
          "name": "夔州·白帝城",
          "x": 78,
          "y": 43,
          "isKey": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "speakerName": "旁白",
              "text": "永泰元年秋，杜甫到夔州。"
            }
          ]
        }
      ],
      "nextPhase": "gao_zhai",
      "narrative": ""
    },
    {
      "id": "gao_zhai",
      "type": "explore",
      "background": "/assets/events/765_kuizhou/backgrounds/kuizhou_gao_zhai.png",
      "title": "高斋·晚秋",
      "narrative": "夔州都督柏茂琳供瀼西草屋，杜甫住下。秋。",
      "instruction": "点击窗外的景与桌前的物，感受这个秋天。",
      "npcs": [
        {
          "id": "window_river",
          "name": "江景窗",
          "portrait": "",
          "position": {
            "x": 60,
            "y": 39
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "speakerName": "旁白",
              "text": "风急天高猿啸哀，渚清沙白鸟飞回。"
            }
          ]
        },
        {
          "id": "falling_leaves",
          "name": "落叶",
          "portrait": "",
          "position": {
            "x": 21,
            "y": 30
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "speakerName": "旁白",
              "text": "无边落木萧萧下，不尽长江滚滚来。"
            }
          ]
        },
        {
          "id": "empty_cup",
          "name": "空酒杯",
          "portrait": "",
          "position": {
            "x": 45,
            "y": 75
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "潦倒新停浊酒杯。",
              "dufu_pose": "drift/writing"
            }
          ]
        },
        {
          "id": "local_boy",
          "name": "当地小厮",
          "portrait": "/assets/characters/npcs/local_boy.png",
          "position": {
            "x": 10,
            "y": 80
          },
          "dialogues": [
            {
              "speaker": "local_boy",
              "speakerName": "当地小厮",
              "text": "先生，柏都督派人送来今日的炭。"
            },
            {
              "speaker": "local_boy",
              "speakerName": "当地小厮",
              "text": "先生身体可还好？"
            },
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "老了。一日不如一日。"
            }
          ]
        },
        {
          "id": "wine_jar",
          "name": "酒坛",
          "portrait": "/assets/props/wine_jar.png",
          "position": {
            "x": 82,
            "y": 75
          },
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "艰难苦恨繁霜鬓……",
              "dufu_pose": "drift/drinking_alone"
            }
          ]
        }
