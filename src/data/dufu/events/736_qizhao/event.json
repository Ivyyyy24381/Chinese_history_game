{
  "id": "736_qizhao",
  "title": "初次落第·壮游",
  "year": "736",
  "type": "interactive",
  "phases": [
    {
      "id": "gongli_study",
      "type": "explore",
      "background": "/assets/events/736_qizhao/backgrounds/gonglixian_study.png",
      "title": "巩县家中",
      "narrative": "公元712年，杜甫出生于河南巩县。祖父杜审言是初唐著名诗人。少年杜甫立志『读万卷书，行万里路』。",
      "instruction": "点击家中物件，了解少年杜甫的志向。",
      "npcs": [
        {
          "id": "desk_books",
          "name": "祖父诗集",
          "portrait": "",
          "position": {
            "x": 35,
            "y": 62
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "speakerName": "旁白",
              "text": "案上摆着祖父杜审言的诗稿——「独有宦游人，偏惊物候新。」"
            },
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "祖父之诗，气象阔大。我亦当如是。"
            }
          ]
        },
        {
          "id": "grandfather_painting",
          "name": "祖父画像",
          "portrait": "",
          "position": {
            "x": 39,
            "y": 29
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "祖父常说：读万卷书，行万里路。"
            }
          ]
        },
        {
          "id": "mother",
          "name": "母亲",
          "portrait": "/assets/characters/npcs/mother.png",
          "position": {
            "x": 68,
            "y": 56
          },
          "scale": 3,
          "dialogues": [
            {
              "speaker": "mother",
              "speakerName": "母亲",
              "text": "子美，又在看书？听说今年又有进士科。"
            },
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "孩儿想先出门看看天下。"
            },
            {
              "speaker": "mother",
              "speakerName": "母亲",
              "text": "……你这孩子，像你祖父。"
            }
          ]
        }
      ],
      "requiredTalks": 3,
      "nextPhase": "failed_exam"
    },
    {
      "id": "failed_exam",
      "type": "transition",
      "background": "/assets/events/736_qizhao/backgrounds/luoyang_gongyuan.png",
      "title": "洛阳贡院·落第",
      "transitionText": "开元二十三年（735），杜甫赴洛阳应进士试……",
      "announcement": {
        "text": "榜单：杜甫——未中。",
        "style": "imperial_decree"
      },
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/portrait.png",
        "text": "不中便不中。天地之大，岂止一榜？"
      },
      "nextPhase": "grand_tour"
    },
    {
      "id": "grand_tour",
      "type": "map_travel",
      "background": "/assets/maps/tang_dynasty.png",
      "title": "齐赵壮游",
      "travelNarrative": "落第后，杜甫从洛阳出发，开始为期数年的齐赵之游。",
      "instruction": "点击每一站，听他在路上的话。",
      "requireAll": true,
      "waypoints": [
        {
          "id": "yanzhou",
          "name": "兖州",
          "x": 64,
          "y": 50,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "父亲在此为司马，先来探望。"
            }
          ]
        },
        {
          "id": "taishan_foot",
          "name": "泰山下",
          "x": 66,
          "y": 48,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "岱宗夫如何？齐鲁青未了……"
            }
          ]
        },
        {
          "id": "taishan_top",
          "name": "泰山绝顶",
          "x": 67,
          "y": 46,
          "isKey": true,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "会当凌绝顶，一览众山小！"
            },
            {
              "speaker": "narrator",
              "speakerName": "旁白",
              "text": "（此刻杜甫写下了《望岳》。）"
            }
          ]
        }
      ],
      "nextPhase": "wangyue_compose"
    },
    {
      "id": "wangyue_compose",
      "type": "poem_compose",
      "background": "/assets/events/736_qizhao/backgrounds/taishan_summit.png",
      "title": "《望岳》",
      "poemContext": "登临绝顶。心中诗句呼之欲出——请把候选词放回正确的空格。",
      "puzzle": "岱宗夫如何？___青未了。\n造化___神秀，___割昏晓。\n荡胸___曾云，决眦入归鸟。\n会当___，一览___。",
      "blanks": [
        "齐鲁",
        "钟",
        "阴阳",
        "生",
        "凌绝顶",
        "众山小"
      ],
      "distractors": [
        "江汉",
        "见",
        "雷电"
      ],
      "poemTitle": "望岳"
    },
    {
      "id": "tour_end",
      "type": "transition",
      "background": "/assets/events/736_qizhao/backgrounds/yellow_river.png",
      "title": "壮游归来",
      "transitionText": "五年之间，\n杜甫走遍齐赵吴越，\n结交豪杰，自比稷契。",
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/portrait.png",
        "text": "李太白……他的诗，我读了十年。听说他也要来洛阳。"
      }
    }
  ]
}