        {
          "id": "desk",
          "name": "桌案",
          "portrait": "",
          "position": {
            "x": 52,
            "y": 59
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "speakerName": "桌案",
              "text": "案上墨迹未干，纸面写着——"
            },
            {
              "speaker": "narrator",
              "speakerName": "桌案",
              "text": "《朝献太清宫赋》"
            }
          ]
        },
        {
          "id": "paper_ball",
          "name": "纸团",
          "portrait": "",
          "position": {
            "x": 86,
            "y": 82
          },
          "scale": 0.3,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "narrator",
              "speakerName": "纸团",
              "text": "拾起一团揉皱的废稿——"
            },
            {
              "speaker": "narrator",
              "speakerName": "废稿",
              "text": "（满纸皆是涂改与删抹）"
            }
          ]
        },
        {
          "id": "label_1778532955294",
          "name": "杜甫",
          "portrait": "",
          "position": {
            "x": 75,
            "y": 31
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "portrait",
              "speakerName": "杜甫",
              "text": "我本不愿作颂圣文章。"
            },
            {
              "speaker": "portrait",
              "speakerName": "杜甫",
              "text": "......"
            },
            {
              "speaker": "portrait",
              "speakerName": "杜甫",
              "text": "可若不如此，又如何让天下听见我的声音？"
            }
          ]
        }
      ],
      "requiredTalks": 3,
      "nextPhase": "writing_choice"
    },
    {
      "id": "writing_puzzle",
