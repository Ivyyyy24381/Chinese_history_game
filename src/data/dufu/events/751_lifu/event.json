{
  "id": "751_lifu",
  "title": "进献三大礼赋",
  "year": "751",
  "type": "interactive",
  "phases": [
    {
      "id": "street_ceremony_eve",
      "type": "explore",
      "background": "/assets/events/751_lifu/backgrounds/changan_ceremony.png",
      "title": "长安街头·大礼前夕",
      "narrative": "天宝十载（751年），玄宗将行三大礼——朝献太清宫、朝享太庙、有事于南郊。长安万民同庆，张灯结彩。",
      "instruction": "和路人交谈，了解这场盛典与「献赋」的机会。",
      "npcs": [
        {
          "id": "merchant_a",
          "name": "商贩甲",
          "portrait": "/assets/characters/npcs/merchant_a.png",
          "position": {
            "x": 18,
            "y": 86
          },
          "scale": 1.8,
          "dialogues": [
            {
              "speaker": "merchant_a",
              "speakerName": "商贩甲",
              "text": "听闻圣人将行三大礼，满朝官员都忙疯了。"
            }
          ]
        },
        {
          "id": "merchant_b",
          "name": "商贩乙",
          "portrait": "/assets/characters/npcs/merchant_b.png",
          "position": {
            "x": 48,
            "y": 74
          },
          "scale": 1.3,
          "flip": true,
          "dialogues": [
            {
              "speaker": "merchant_b",
              "speakerName": "商贩乙",
              "text": "朝献太清宫、朝享太庙，还要祭天南郊。"
            },
            {
              "speaker": "merchant_b",
              "speakerName": "商贩乙",
              "text": "这等盛典，十几年都难得一见。"
            }
          ]
        },
        {
          "id": "waiter",
          "name": "酒店伙计",
          "portrait": "/assets/characters/npcs/waiter.png",
          "position": {
            "x": 75,
            "y": 75
          },
          "scale": 1.3,
          "flip": true,
          "dialogues": [
            {
              "speaker": "waiter",
              "speakerName": "酒店伙计",
              "text": "近日长安纸价都涨了。"
            },
            {
              "speaker": "waiter",
              "speakerName": "酒店伙计",
              "text": "那些读书人啊，都在连夜写赋。"
            }
          ]
        },
        {
          "id": "scholar_a",
          "name": "士人甲",
          "portrait": "/assets/characters/npcs/scholar_a.png",
          "position": {
            "x": 60,
            "y": 73
          },
          "scale": 1.3,
          "dialogues": [
            {
              "speaker": "scholar_a",
              "speakerName": "士人甲",
              "text": "若文章能入圣人之眼，未必不能一步登天。"
            }
          ]
        },
        {
          "id": "scholar_b",
          "name": "士人乙",
          "portrait": "/assets/characters/npcs/scholar_b.png",
          "position": {
            "x": 34,
            "y": 76
          },
          "scale": 1.5,
          "dialogues": [
            {
              "speaker": "scholar_b",
              "speakerName": "士人乙",
              "text": "只是献赋这种事——"
            },
            {
              "speaker": "scholar_b",
              "speakerName": "士人乙",
              "text": "献的是文章，还是颂圣之辞？"
            }
          ]
        },
        {
          "id": "elder",
          "name": "喝酒老人",
          "portrait": "/assets/characters/npcs/elder.png",
          "position": {
            "x": 84,
            "y": 77
          },
          "scale": 1.3,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "elder",
              "speakerName": "喝酒老人",
              "text": "长安城里，从不缺会写文章的人。"
            },
            {
              "speaker": "elder",
              "speakerName": "喝酒老人",
              "text": "缺的是……"
            },
            {
              "speaker": "elder",
              "speakerName": "喝酒老人",
              "text": "能让皇帝看见的人。"
            }
          ]
        }
      ],
      "requiredTalks": 3,
      "nextPhase": "residence"
    },
    {
