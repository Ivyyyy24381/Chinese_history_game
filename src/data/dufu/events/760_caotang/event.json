{
  "id": "760_caotang",
  "title": "草堂时期",
  "year": "760",
  "type": "interactive",
  "phases": [
    {
      "id": "huanhuaxi",
      "type": "explore",
      "background": "/assets/events/760_caotang/backgrounds/huanhuaxi.png",
      "title": "浣花溪畔",
      "narrative": "乾元三年春（760）。成都西郊浣花溪畔。",
      "instruction": "在溪边走一走，决定把草堂建在哪里。",
      "npcs": [
        {
          "id": "bamboo_grove",
          "name": "竹林",
          "portrait": "",
          "position": {
            "x": 13,
            "y": 62
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "竹叶清风，可栖。",
              "dufu_pose": "drift/holding_child"
            }
          ]
        },
        {
          "id": "stream",
          "name": "溪水",
          "portrait": "",
          "position": {
            "x": 43,
            "y": 80
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "水足，可灌园。",
              "dufu_pose": "drift/holding_child"
            }
          ]
        },
        {
          "id": "old_tree",
          "name": "老树",
          "portrait": "",
          "position": {
            "x": 37,
            "y": 27
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "百年楠木——荫下可读书。",
              "dufu_pose": "drift/holding_child"
            }
          ]
        },
        {
          "id": "yanwu",
          "name": "严武",
          "portrait": "/assets/characters/npcs/yanwu.png",
          "position": {
            "x": 74,
            "y": 57
          },
          "scale": 1.8,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "yanwu",
              "speakerName": "严武",
              "text": "子美兄，我已让人送来材料。"
            },
            {
              "speaker": "yanwu",
              "speakerName": "严武",
              "text": "这草堂虽简陋，但足以避风雨。"
            },
            {
              "speaker": "yanwu",
              "speakerName": "严武",
              "text": "需要什么，随时来节度使府。"
            }
          ]
        }
      ],
      "requiredTalks": 3,
      "nextPhase": "build"
    },
    {
      "id": "build",
      "type": "explore",
      "background": "/assets/events/760_caotang/backgrounds/caotang_building.png",
      "title": "起屋",
      "narrative": "春末，草堂初成。",
      "instruction": "依次点击四个建筑要素，把家安顿下来。",
      "npcs": [
        {
          "id": "roof",
          "name": "屋顶（茅）",
          "portrait": "",
          "position": {
            "x": 39,
            "y": 30
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "茅卷三重，足以蔽日。",
              "dufu_pose": "drift/holding_child"
            }
          ]
        },
        {
          "id": "fence",
          "name": "篱笆",
          "portrait": "",
          "position": {
            "x": 30,
            "y": 75
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "桤林碍日吟风叶，笼竹和烟滴露梢。",
              "dufu_pose": "drift/holding_child"
            }
          ]
        },
        {
          "id": "herb_garden",
          "name": "药圃",
          "portrait": "",
          "position": {
            "x": 9,
            "y": 55
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "种药今多归散吏。",
              "dufu_pose": "drift/drinking_alone"
            }
          ]
        },
        {
          "id": "pond",
          "name": "池塘",
          "portrait": "",
          "position": {
            "x": 93,
            "y": 74
          },
          "isClue": true,
          "dialogues": [
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "澄江平少岸，幽树晚多花。",
              "dufu_pose": "drift/holding_child"
            },
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "这浣花溪畔，山清水秀，终于可以安定下来了。",
              "dufu_pose": "drift/writing"
            }
          ]
        }
      ],
      "requiredTalks": 3,
      "nextPhase": "daily_life"
    },
    {
      "id": "daily_life",
      "type": "explore",
      "background": "/assets/events/760_caotang/backgrounds/caotang_yard.png",
      "title": "草堂的客人",
      "narrative": "草堂落成，故人陆续到访。",
      "instruction": "和两位客人聊聊。",
      "npcs": [
        {
          "id": "yanwu_visit",
          "name": "严武再访",
          "portrait": "/assets/characters/npcs/yanwu.png",
          "position": {
            "x": 16,
            "y": 75
          },
          "scale": 1.4,
          "dialogues": [
            {
              "speaker": "yanwu_visit",
              "speakerName": "严武",
              "text": "这几日朝廷召我入京，下次见不知何时。"
            },
            {
              "speaker": "yanwu_visit",
              "speakerName": "严武",
              "text": "子美保重——若我不在成都，恐怕……"
            }
          ]
        },
        {
          "id": "gaoshi_visit",
          "name": "高适",
          "portrait": "/assets/characters/npcs/gaoshi.png",
          "position": {
            "x": 69,
            "y": 68
          },
          "scale": 1.3,
          "isClue": true,
          "dialogues": [
            {
              "speaker": "gaoshi_visit",
              "speakerName": "高适",
              "text": "子美，多年不见。当年梁宋之游，恍如昨日。"
            },
            {
              "speaker": "gaoshi_visit",
              "speakerName": "高适",
              "text": "太白……前年已死于当涂。"
            },
            {
              "speaker": "dufu",
              "speakerName": "杜甫",
              "text": "……"
            }
          ]
        },
        {
          "id": "farmer",
          "name": "邻翁",
          "portrait": "/assets/characters/npcs/farmer.png",
          "position": {
            "x": 91,
            "y": 74
          },
          "scale": 1.2,
          "flip": true,
          "dialogues": [
            {
              "speaker": "farmer",
              "speakerName": "邻翁",
              "text": "先生今日又有客？我送了些新麦。"
            },
            {
              "speaker": "farmer",
              "speakerName": "邻翁",
              "text": "南邻的崔老头说先生的诗在长安都传开了。"
            }
          ]
        },
        {
          "id": "boy",
          "name": "邻家小儿",
          "portrait": "/assets/characters/npcs/boy.png",
          "position": {
            "x": 46,
            "y": 68
          },
          "scale": 0.9,
          "dialogues": [
            {
              "speaker": "boy",
              "speakerName": "邻家小儿",
              "text": "杜公！我们今日又来抢茅！"
            },
            {
              "speaker": "narrator",
              "speakerName": "旁白",
              "text": "（笑闹间跑开。）"
            }
          ]
        }
      ],
      "requiredTalks": 3,
      "nextPhase": "storm"
    },
    {
      "id": "storm",
      "type": "transition",
      "background": "/assets/events/760_caotang/backgrounds/caotang_storm.png",
      "title": "秋风",
      "transitionText": "八月秋高风怒号，\n卷我屋上三重茅。\n茅飞渡江洒江郊，\n高者挂罥长林梢。",
      "announcement": {
        "text": "「南村群童欺我老无力，忍能对面为盗贼。」",
        "style": "imperial_decree"
      },
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/drift/walking.png",
        "text": "归来倚杖自叹息。"
      },
      "nextPhase": "maowu_compose",
      "narrative": ""
    },
    {
      "id": "maowu_compose",
      "type": "poem_compose",
      "background": "/assets/events/760_caotang/backgrounds/caotang_rain.png",
      "title": "《茅屋为秋风所破歌》末段",
      "poemContext": "冷雨入床。布衾多年冷似铁。心中却升起一个念头——把候选词填到正确的位置。",
      "puzzle": "安得___，大庇天下___！\n风雨___！\n呜呼！何时眼前突兀见此屋，吾庐___！",
      "blanks": [
        "广厦千万间",
        "寒士俱欢颜",
        "不动安如山",
        "独破受冻死亦足"
      ],
      "distractors": [
        "金堂玉马间",
        "故人尽白头",
        "稳渡江湖船"
      ],
      "poemTitle": "茅屋为秋风所破歌（末段）",
      "narrative": "",
      "poemAnswer": "",
      "poemCandidates": []
    },
    {
      "id": "leave_caotang",
      "type": "transition",
      "background": "/assets/events/760_caotang/backgrounds/caotang_empty.png",
      "title": "离开草堂",
      "transitionText": "广德二年（764），严武再镇蜀，杜甫一度任工部员外郎。\n永泰元年（765）严武病逝。\n杜甫失去依靠，乘船东下。",
      "dufu_reaction": {
        "portrait": "/assets/characters/dufu/portrait.png",
        "text": "这一住，已是五年。"
      }
    }
  ]
